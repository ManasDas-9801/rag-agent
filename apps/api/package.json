{
  "name": "@rag/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "worker": "node ../../node_modules/tsx/dist/cli.mjs watch src/worker.ts",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "node ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node ../../node_modules/tsx/dist/cli.mjs src/scripts/migrate.ts",
    "admin:promote": "node ../../node_modules/tsx/dist/cli.mjs src/scripts/promote-admin.ts",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs",
    "lint": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@google/generative-ai": "^0.24.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.10",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "drizzle-zod": "^0.6.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "mammoth": "^1.9.0",
    "mime-types": "^2.1.35",
    "nanoid": "^5.0.9",
    "openai": "^4.77.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
