# API (apps/api)
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://rag:rag@localhost:5432/rag
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
BCRYPT_ROUNDS=12

# --- LLM provider: "openai" | "gemini" ---
AI_PROVIDER=gemini

# OpenAI (required when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Google Gemini (required when AI_PROVIDER=gemini; get a key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Chunking defaults (overridable per workspace in DB later)
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
EMBEDDING_BATCH_SIZE=64
# Must match pgvector column (1536). Gemini text-embedding-004 supports this output size.
EMBEDDING_DIMENSIONS=1536

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# Web (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Super admin: see docs/ADMIN.md
#   npm run admin:promote -- your@email.com
# Admin UI: http://localhost:3000/admin
